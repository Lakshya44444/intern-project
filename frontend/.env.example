# ── Supabase (required for login / register) ──────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# ── Backend environment variables (set in terminal before running app.py) ─────
# SUPABASE_JWT_SECRET=your_jwt_secret_here   (Settings → API → JWT Secret)
#                                             If not set, auth is bypassed (dev mode)
# ANTHROPIC_API_KEY=your_key_here            (optional — enables Vision extraction)

# ── Run commands ──────────────────────────────────────────────────────────────
# Backend:  python app.py   OR   uvicorn app:app --host 0.0.0.0 --port 5000 --reload
# Frontend: npm run dev   (in frontend/ directory)
